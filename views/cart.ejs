<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart - Canvas Couture</title>
    <link rel="stylesheet" href="/css/cartStyle.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/js/cartFunctions.js" defer></script>
</head>

<body>
    <div class="container">
        <h1>HINT: A04:2021-Insecure Design</h1>

        <% if (cart && cart.length> 0) { %>
            <div class="cart">
                <table>
                    <thead>
                        <tr>
                            <th>Product Name</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Remove</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% let totalAmount=0; %>
                            <% cart.forEach(order=> { %>
                                <% order.items.forEach(item=> { %>
                                    <% if (item.quantity> 0) { %>
                                        <tr id="item-<%= item.productId %>">
                                            <td>
                                                <%= item.name %>
                                            </td>
                                            <td><span class="item-quantity">
                                                    <%= item.quantity %>
                                                </span></td>
                                            <td>$<span class="item-price">
                                                    <%= item.price %>
                                                </span></td>
                                            <td>
                                                <div class="button-group">
                                                    <button class="minus-btn"
                                                        onclick="removeFromCart('<%= order.orderId %>', '<%= item.productId %>')">-</button>
                                                    <button class="plus-btn"
                                                        onclick="addToCart('<%= item.productId %>', 1)">+</button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                                            <% totalAmount +=item.price * item.quantity; %>
                                                <% }) %>
                                                    <% }) %>
                    </tbody>
                </table>
                <div class="total">
                    <h2>Total Amount: $<%= totalAmount.toFixed(2) %>
                    </h2>


                    <button class="btn btn-payment" id="proceed-payment">Proceed to Payment</button>

                    <% if (totalAmount < 0) { %>
                        <button class="btn btn-payment" id="proceed-payment">FLAG{MOMMY_IM_RICH}</button>
                        <% } %>

                </div>
            </div>
            <% } %>
    </div>
    <div class="text-center mt-5">
        <button class="btn btn-back" id="back-to-shop">Back to Shop</button>
    </div>
</body>

</html>